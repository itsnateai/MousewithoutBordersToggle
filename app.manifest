<?xml version="1.0" encoding="utf-8"?>
<assembly manifestVersion="1.0" xmlns="urn:schemas-microsoft-com:asm.v1">
  <assemblyIdentity version="1.0.0.0" name="MWBToggle" />

  <!-- DPI awareness is declared in MWBToggle.csproj (<ApplicationHighDpiMode>PerMonitorV2</ApplicationHighDpiMode>)
       + Program.cs Application.SetHighDpiMode, NOT here. dpiAwareness in the manifest triggers compiler
       warning WFAC010 for .NET WinForms (it conflicts with / overrides the csproj setting). -->
  <application xmlns="urn:schemas-microsoft-com:asm.v3">
    <windowsSettings>
      <!-- Opt into Windows 10 1607+ long-path support for log paths under
           %LOCALAPPDATA%\MWBToggle and settings paths under PowerToys on
           roaming profiles with long usernames. -->
      <longPathAware xmlns="http://schemas.microsoft.com/SMI/2016/WindowsSettings">true</longPathAware>
    </windowsSettings>
  </application>

  <!-- Declare Win10 + Win11 compatibility so the OS doesn't lie about the version
       to GetVersionEx-style calls (none today, but future-proof). -->
  <compatibility xmlns="urn:schemas-microsoft-com:compatibility.v1">
    <application>
      <!-- Windows 10 and Windows 11 -->
      <supportedOS Id="{8e0f7a12-bfb3-4fe8-b9a5-48fd50a15a9a}" />
    </application>
  </compatibility>
</assembly>
